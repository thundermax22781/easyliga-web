{
  "name": "frontend",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo export --platform web",
    "lint": "expo lint",
    "build:bundle": "if not exist \"android\\app\\src\\main\\assets\" mkdir \"android\\app\\src\\main\\assets\" && npx react-native bundle --platform android --dev false --entry-file index.js --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res",
    "build:apk": "npm run build:bundle && cd android && .\\gradlew assembleRelease",
    "build:debug-clean": "cd android && .\\gradlew clean && cd .. && npm run build:bundle && cd android && .\\gradlew assembleDebug"
  },
  "dependencies": {
    "@babel/runtime": "^7.20.6",
    "@expo/metro-runtime": "~4.0.0",
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "~14.0.4",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/datetimepicker": "8.2.0",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "@supabase/supabase-js": "^2.101.1",
    "expo": "~52.0.25",
    "expo-asset": "~11.0.5",
    "expo-blur": "~14.0.1",
    "expo-clipboard": "~7.0.1",
    "expo-constants": "~17.0.8",
    "expo-document-picker": "~13.0.1",
    "expo-file-system": "~18.0.7",
    "expo-font": "~13.0.2",
    "expo-haptics": "~14.0.0",
    "expo-image": "~2.0.3",
    "expo-image-picker": "~16.0.3",
    "expo-linking": "~7.0.3",
    "expo-notifications": "~0.29.14",
    "expo-router": "~4.0.15",
    "expo-sharing": "~13.0.1",
    "expo-splash-screen": "~0.29.18",
    "expo-status-bar": "~2.0.0",
    "expo-symbols": "~0.2.0",
    "expo-system-ui": "~4.0.6",
    "expo-web-browser": "~14.0.1",
    "firebase": "^12.11.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-dotenv": "^3.4.11",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "~0.19.13",
    "react-native-webview": "13.12.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@react-native-community/cli": "^20.1.3",
    "@types/react": "~18.3.12",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~8.0.1",
    "typescript": "~5.3.3"
  },
  "private": true
}
